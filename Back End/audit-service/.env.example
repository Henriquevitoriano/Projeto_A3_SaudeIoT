# Copie para .env e ajuste. NUNCA comite o .env real.

# === MONGODB (auditoria) ===
# Idealmente um cluster SEPARADO do principal. No MVP, mesmo cluster,
# banco lógico distinto. Trocando MONGO_URL_AUDIT para um cluster próprio
# em produção, NENHUMA mudança de código é necessária.
MONGO_URL_AUDIT=mongodb+srv://USUARIO:SENHA@cluster.mongodb.net/?retryWrites=true&w=majority
MONGO_DB_AUDIT=uti_auditoria
MONGO_COLLECTION_AUDIT=eventos

# === HTTP ===
HTTP_PORTA=8084

# === TOKEN COMPARTILHADO ===
# DEVE ser idêntico ao do patients-service (.env). Sem ele, nenhum serviço
# consegue gravar evento.
AUDIT_SHARED_TOKEN=cole_aqui_64_chars_hex
