# Copie para .env e ajuste. NUNCA comite o .env real.

# === MONGODB (auditoria) ===
# Idealmente um cluster SEPARADO do principal. No MVP, mesmo cluster,
# banco lógico distinto. Trocando MONGO_URL para um cluster próprio
# em produção, NENHUMA mudança de código é necessária (cada serviço tem
# seu próprio .env, isolado dos demais).
MONGO_URL=mongodb+srv://USUARIO:SENHA@cluster.mongodb.net/?retryWrites=true&w=majority
MONGO_DB=uti_auditoria
MONGO_COLLECTION=eventos

# === HTTP ===
HTTP_PORTA=8084

# === TOKEN COMPARTILHADO ===
# DEVE ser idêntico ao do patients-service (.env). Sem ele, nenhum serviço
# consegue gravar evento.
AUDIT_SHARED_TOKEN=cole_aqui_64_chars_hex
