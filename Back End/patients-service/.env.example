# Copie para .env e ajuste. NUNCA comite o .env real.

# === MONGODB (PII) ===
MONGO_URL_PII=mongodb+srv://USUARIO:SENHA@cluster.mongodb.net/?retryWrites=true&w=majority
MONGO_DB_PII=uti_pacientes
MONGO_COLLECTION_PII=pacientes

# === CHAVE DE CRIPTOGRAFIA ===
# Gere uma vez: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PII_ENCRYPTION_KEY=cole_aqui_64_chars_hex

# === HTTP ===
HTTP_PORTA=8082

# === AUDIT SERVICE (Passo 8) ===
# Onde está o audit-service. Se ele estiver fora, reidentificação FALHA
# (fail-closed — LGPD Art. 37: sem registro, sem operação).
AUDIT_URL=http://localhost:8084
# Segredo compartilhado entre patients-service e audit-service.
# PRECISA ser igual nos dois .env. Gere com:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUDIT_SHARED_TOKEN=cole_aqui_64_chars_hex
