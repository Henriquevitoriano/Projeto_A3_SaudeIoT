# Copie para .env e ajuste. NUNCA comite o .env real.

# === JWT ===
# Gere com: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# MINIMO 32 caracteres. Se vazar, qualquer um forja tokens — TROQUE imediatamente.
JWT_SECRET=cole_aqui_48_bytes_em_hex
JWT_EXPIRACAO=1h

# === USUÁRIOS ===
# Rode 'npm run gerar-hash' para gerar e copie a linha gerada para cá.
# Formato: JSON em UMA LINHA, com aspas simples envolvendo.
USUARIOS_JSON='[{"login":"dr.silva","hash":"$2a$...","role":"medico","nome":"Dr. Silva"}]'

# === SERVIÇOS INTERNOS ===
# IMPORTANTE: em produção, esses serviços devem escutar APENAS em 127.0.0.1
# (loopback), não em 0.0.0.0. Assim ninguém de fora alcança eles direto.
PATIENTS_URL=http://localhost:8082
QUERY_URL=http://localhost:8083

# === HTTP ===
HTTP_PORTA=8080

# === CORS ===
# Origem permitida a chamar este Gateway (o dashboard). Em produção, configure
# para o domínio real do dashboard.
CORS_ORIGEM=http://localhost:8090
