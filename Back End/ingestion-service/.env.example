# Copie para .env e ajuste. NUNCA comite o .env real (contém credenciais).

# === MQTT ===
# Em dev local (Mosquitto via Docker, ou o broker Aedes em Back End/mqtt-broker):
MQTT_URL=mqtt://localhost:1883
# Em produção (HiveMQ Cloud), exemplo:
# MQTT_URL=mqtts://seu-cluster.hivemq.cloud:8883
# MQTT_USER=seu_usuario
# MQTT_PASS=sua_senha

# === MONGODB ATLAS ===
# Cole AQUI a connection string do Atlas, substituindo <db_password> pela senha real.
# Este serviço deve usar uma conta com permissão de escrita no banco de sinais.
# Exemplo (NÃO USAR como está — é só ilustrativo):
MONGO_URL=mongodb+srv://uti_ingestion_service:SUA_SENHA_AQUI@cluster0.95pjsez.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0
MONGO_DB=uti_monitor
MONGO_COLLECTION=sinais_vitais
